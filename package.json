{
  "name": "@loops-adk/core",
  "version": "0.1.1",
  "license": "MIT",
  "author": "Jonny Neill",
  "description": "Run an agent in a convergence loop with an honest done-gate. A small, nestable loop and DAG primitive: deterministic plus agent-judge conditions, git as memory, review-restart, budgets, and a live TUI.",
  "keywords": [
    "agent",
    "agents",
    "loop",
    "loops",
    "convergence",
    "ai",
    "llm",
    "claude",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonny981/loops.git"
  },
  "homepage": "https://github.com/jonny981/loops#readme",
  "bugs": {
    "url": "https://github.com/jonny981/loops/issues"
  },
  "type": "module",
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "bin": {
    "loops": "./bin/loops.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./env/command": {
      "types": "./dist/env/command.d.ts",
      "import": "./dist/env/command.js"
    },
    "./env/sst": {
      "types": "./dist/env/sst.d.ts",
      "import": "./dist/env/sst.js"
    },
    "./env/docker": {
      "types": "./dist/env/docker.d.ts",
      "import": "./dist/env/docker.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "loops": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:ab": "tsx bench/ab.ts",
    "bench:graph": "tsx bench/graph.ts",
    "bench:report": "tsx bench/report.ts",
    "bench:report:sample": "tsx bench/report.ts bench/results.sample.json",
    "bench:context:dry": "BENCH_DRY=1 BENCH_CB_GROUPS=bench/contextbench/groups.dry.json tsx bench/swecontextbench.ts",
    "example:poll": "tsx src/index.ts run examples/simple-poll.loop.ts --no-tui",
    "example:gate": "tsx src/index.ts run examples/confidence-gate.loop.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@anthropic-ai/sdk": "^0.105.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "ink": "^7.1.0",
    "ms": "^2.1.3",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "p-timeout": "^7.0.1",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "toposort": "^2.0.2",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/toposort": "^2.0.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
